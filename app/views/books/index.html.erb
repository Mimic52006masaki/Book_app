<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <title>読書ログ一覧 - 読書ログアプリ</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-800 font-sans min-h-screen flex flex-col">
  <header class="bg-blue-600 text-white p-4 shadow">
    <div class="container mx-auto flex justify-between items-center">
      <h1 class="text-2xl font-bold">読書ログ一覧</h1>
      <nav>
        <%= link_to '本の登録', new_book_path, class: 'bg-blue-500 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded' %>
      </nav>
    </div>
  </header>

  <main class="container mx-auto flex-grow py-8">
    <% if notice %>
      <div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded">
        <%= notice %>
      </div>
    <% end %>

    <table class="w-full bg-white rounded shadow overflow-hidden">
      <thead class="bg-blue-600 text-white">
        <tr>
          <th class="px-4 py-2 text-left">タイトル</th>
          <th class="px-4 py-2 text-left">著者</th>
          <th class="px-4 py-2 text-left">読了日</th>
          <th class="px-4 py-2 text-left">評価</th>
          <th class="px-4 py-2">操作</th>
        </tr>
      </thead>
      <tbody>
        <% @books.each do |book| %>
          <tr class="border-b hover:bg-gray-50">
            <td class="px-4 py-2"><%= link_to book.title, book_path(book), class: "text-blue-600 hover:underline" %></td>
            <td class="px-4 py-2"><%= book.author %></td>
            <td class="px-4 py-2"><%= book.read_date.strftime('%Y-%m-%d') %></td>
            <td class="px-4 py-2">
              <%# 星評価を★で表示 %>
              <%= '★' * book.rating + '☆' * (5 - book.rating) %>
            </td>
            <td class="px-4 py-2 space-x-2">
              <%= link_to '編集', edit_book_path(book), class: "bg-green-500 hover:bg-green-600 text-white py-1 px-3 rounded" %>
              <%= link_to '削除', book_path(book), method: :delete, data: { confirm: '本を削除してもよろしいですか？' }, class: "bg-red-500 hover:bg-red-600 text-white py-1 px-3 rounded" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @books.empty? %>
      <p class="mt-6 text-center text-gray-600">登録された本はまだありません。</p>
    <% end %>
  </main>

  <footer class="bg-gray-700 text-white p-4 text-center">
    <p>&copy; 2023 読書ログアプリ. All rights reserved.</p>
  </footer>
</body>
</html>
