<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <title>本の詳細 - 読書ログアプリ</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 text-gray-800 font-sans min-h-screen flex flex-col">
  <header class="bg-blue-600 text-white p-4 shadow">
    <div class="container mx-auto flex justify-between items-center">
      <h1 class="text-2xl font-bold">本の詳細</h1>
      <nav>
        <%= link_to '一覧に戻る', books_path, class: 'bg-gray-500 hover:bg-gray-700 text-white font-semibold py-2 px-4 rounded' %>
      </nav>
    </div>
  </header>

  <main class="container mx-auto flex-grow py-8">
    <% if notice %>
      <div class="mb-6 p-4 bg-green-100 border border-green-400 text-green-700 rounded">
        <%= notice %>
      </div>
    <% end %>

    <section class="bg-white p-6 rounded shadow max-w-3xl mx-auto">
      <h2 class="text-3xl font-semibold mb-4"><%= @book.title %></h2>

      <p class="mb-2"><strong>著者:</strong> <%= @book.author %></p>
      <p class="mb-2"><strong>読了日:</strong> <%= @book.read_date.strftime('%Y-%m-%d') %></p>
      <p class="mb-4"><strong>評価:</strong> <%= '★' * @book.rating + '☆' * (5 - @book.rating) %></p>

      <div class="mb-6">
        <strong>感想:</strong>
        <p class="whitespace-pre-wrap mt-2"><%= @book.thoughts.presence || "感想はまだ登録されていません。" %></p>
      </div>

      <div class="flex gap-4">
        <%= button_to '編集する', edit_book_path(@book), class: 'bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded' %>
        <%= button_to '削除する', book_path(@book), method: :delete, data: { confirm: '本を削除してもよろしいですか？' }, class: 'bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded' %>
      </div>
    </section>
  </main>

  <footer class="bg-gray-700 text-white p-4 text-center">
    <p>&copy; 2023 読書ログアプリ. All rights reserved.</p>
  </footer>
</body>
</html>
